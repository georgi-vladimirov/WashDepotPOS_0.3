{
  "file_types": {
    "Django": [
      "**/templates/**/*.html"
    ]
  },
  "languages": {
    "Python": {
      "language_servers": [
        "pyright"
      ],
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "ruff",
          "arguments": [
            "format",
            "--stdin-filename",
            "{buffer_path}",
            "-"
          ]
        }
      }
    },
    "Django": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "djlint",
          "arguments": [
            "--reformat",
            "-"
          ]
        }
      },
      "language_servers": [
        "django-template-lsp",
        "..."
      ]
    },
    "HTML": {
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": [
            "--stdin-filepath",
            "{buffer_path}"
          ]
        }
      }
    }
  },
  "lsp": {
    "pyright": {
      "settings": {
        "python": {
          "pythonPath": ".venv/bin/python",
          "analysis": {
            "djangoStubs": true,
            "typeCheckingMode": "basic"
          }
        }
      }
    },
    "django-template-lsp": {
      "binary": {
        "path": "E:\\Web Dev\\WashDepotPOS_0.3\\.venv\\Scripts\\djlsp.exe",
        "ignore_system_version": true
      }
    }
  },
  "terminal": {
    "env": {
      "DJANGO_SETTINGS_MODULE": "CarWashPOS.settings",
      "PYTHONPATH": "CarWashPOS"
    }
  }
}

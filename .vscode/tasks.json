{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "djlint: format templates",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": [
        "-m",
        "djlint",
        "CarWashPOS/templates",
        "--reformat"
      ],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "djlint: check templates",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": [
        "-m",
        "djlint",
        "CarWashPOS/templates",
        "--check",
        "--lint"
      ],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
